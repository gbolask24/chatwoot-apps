    {
      "id": "node-code-017",
      "name": "Build Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [4420, 300],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const cfg = $('Set Config').first().json;\n\n// safeGet returns null if node errored (continueOnFail) or didn't run\nconst safeGet = (n) => {\n  try {\n    const j = $(n).first().json;\n    // n8n wraps 404/error responses in {error:{...}} when continueOnFail is set\n    if (j?.error || j?.message?.includes('not found') || j?.statusCode >= 400) return null;\n    return j;\n  } catch { return null; }\n};\n\n// safeGetAll filters out error items\nconst safeGetAll = (n) => {\n  try {\n    return $(n).all()\n      .map(i => i.json)\n      .filter(j => j && !j.error && !(j.statusCode >= 400));\n  } catch { return []; }\n};\n\nconst fmtSeconds = (s) => {\n  if (!s || isNaN(s)) return 'N/A';\n  s = Math.round(s);\n  if (s < 60) return s + 's';\n  if (s < 3600) return Math.floor(s/60) + 'm ' + (s%60) + 's';\n  return Math.floor(s/3600) + 'h ' + Math.floor((s%3600)/60) + 'm';\n};\n\nconst summary    = safeGet('Fetch Account Summary');\nconst convVolume = safeGetAll('Fetch Conv Volume');\nconst resTrend   = safeGetAll('Fetch Resolution Trend');\nconst rawAgents  = safeGetAll('Fetch Agents List');\nconst rawTeams   = safeGetAll('Fetch Teams List');\nconst rawLabels  = safeGet('Fetch Labels List')?.payload ?? safeGetAll('Fetch Labels List');\nconst rawInboxes = safeGet('Fetch Inboxes List')?.payload ?? safeGetAll('Fetch Inboxes List');\n\n// CSAT — endpoint may not exist on this Chatwoot version\nconst csatRaw    = safeGet('Fetch CSAT Reports');\nconst csatRows   = Array.isArray(csatRaw?.data) ? csatRaw.data : [];\n\n// Overview tables — endpoints may not exist on this Chatwoot version\nconst agentOv    = safeGetAll('Fetch Agent Conv Overview');\nconst teamOv     = safeGetAll('Fetch Team Conv Overview');\nconst inboxOv    = safeGetAll('Fetch Inbox Conv Overview');\nconst labelOv    = safeGetAll('Fetch Label Conv Overview');\n\nconst totalR   = csatRows.length;\nconst sumR     = csatRows.reduce((a,r) => a+(r.rating??0), 0);\nconst posCount = csatRows.filter(r=>r.rating>=4).length;\nconst negCount = csatRows.filter(r=>r.rating<=2).length;\n\nconst agentRows = rawAgents.map(agent => {\n  const ov = agentOv.find(o=>o.id===agent.id)??{};\n  const ar  = csatRows.filter(r=>r.assigned_agent?.id===agent.id);\n  return {\n    id: agent.id, name: agent.name, email: agent.email,\n    availability: agent.availability_status,\n    assigned: ov.conversations_count??0,\n    resolved: ov.resolutions_count??0,\n    resolutionRate: ov.conversations_count ? Math.round((ov.resolutions_count/ov.conversations_count)*100) : 0,\n    avgFirstResponse:  fmtSeconds(ov.avg_first_response_time),\n    avgResolutionTime: fmtSeconds(ov.avg_resolution_time),\n    csatRating: ar.length ? (ar.reduce((a,r)=>a+r.rating,0)/ar.length).toFixed(1) : null\n  };\n});\n\nconst teamRows = rawTeams.map(team => {\n  const ov = teamOv.find(o=>o.id===team.id)??{};\n  return {\n    id: team.id, name: team.name, agentCount: team.agents_count??0,\n    conversations: ov.conversations_count??0, resolved: ov.resolutions_count??0,\n    resolutionRate: ov.conversations_count ? Math.round((ov.resolutions_count/ov.conversations_count)*100) : 0,\n    avgFirstResponse: fmtSeconds(ov.avg_first_response_time),\n    avgResolutionTime: fmtSeconds(ov.avg_resolution_time)\n  };\n});\n\nconst inboxRows = (Array.isArray(rawInboxes)?rawInboxes:[]).map(inbox => {\n  const ov = inboxOv.find(o=>o.id===inbox.id)??{};\n  return {\n    id: inbox.id, name: inbox.name, channelType: inbox.channel_type,\n    conversations: ov.conversations_count??0, resolved: ov.resolutions_count??0,\n    pending: ov.open_conversations_count??0,\n    avgFirstResponse: fmtSeconds(ov.avg_first_response_time),\n    avgResolutionTime: fmtSeconds(ov.avg_resolution_time)\n  };\n});\n\nconst labelRows = (Array.isArray(rawLabels)?rawLabels:[]).map(label => {\n  const ov = labelOv.find(o=>o.id===label.id||o.title===label.title)??{};\n  return {\n    id: label.id, title: label.title, color: label.color,\n    conversations: ov.conversations_count??0, resolved: ov.resolutions_count??0,\n    avgResolutionTime: fmtSeconds(ov.avg_resolution_time)\n  };\n});\n\nreturn [{ json: {\n  meta: {\n    generatedAt: new Date().toISOString(),\n    period: { since: cfg.since, until: cfg.until, groupBy: cfg.groupBy }\n  },\n  summary: {\n    totalConversations: summary?.conversations_count??0,\n    resolved:           summary?.resolutions_count??0,\n    incomingMessages:   summary?.incoming_messages_count??0,\n    outgoingMessages:   summary?.outgoing_messages_count??0,\n    avgFirstResponse:   fmtSeconds(summary?.avg_first_response_time),\n    avgResolutionTime:  fmtSeconds(summary?.avg_resolution_time),\n    replyTime:          fmtSeconds(summary?.reply_time)\n  },\n  charts: {\n    conversationVolume: convVolume.map(p=>({ date: new Date(p.timestamp*1000).toLocaleDateString('en-US',{month:'short',day:'numeric'}), value: p.value })),\n    resolutionTrend:    resTrend.map(p=>({ date: new Date(p.timestamp*1000).toLocaleDateString('en-US',{month:'short',day:'numeric'}), value: p.value }))\n  },\n  csat: {\n    score: totalR>0?Math.round((posCount/totalR)*100):null,\n    avgRating: totalR>0?parseFloat((sumR/totalR).toFixed(1)):null,\n    totalResponses: totalR, positive: posCount, negative: negCount,\n    ratingDistribution: [5,4,3,2,1].map(star=>({\n      stars: star,\n      count: csatRows.filter(r=>r.rating===star).length,\n      pct: totalR>0?Math.round(csatRows.filter(r=>r.rating===star).length/totalR*100):0\n    })),\n    recentResponses: csatRows.slice(0,50).map(r=>({\n      rating: r.rating, feedback: r.feedback_message,\n      agent: r.assigned_agent?.name??'Unassigned',\n      contact: r.contact?.name??'Unknown', createdAt: r.created_at\n    }))\n  },\n  agents: agentRows, teams: teamRows, inboxes: inboxRows, labels: labelRows\n}}];\n"
      }
    },

    {
      "id": "node-code-018",
      "name": "Save to Cache",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [4640, 300],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const fs   = require('fs');\nconst path = require('path');\n\nconst cachePath = $('Set Config').first().json.cachePath;\nconst cacheDir  = path.dirname(cachePath);\n\n// Ensure directory exists\nif (!fs.existsSync(cacheDir)) fs.mkdirSync(cacheDir, { recursive: true });\n\nconst now         = new Date();\nconst nextRefresh = new Date(now.getTime() + 60 * 60 * 1000); // +1 hour\n\nconst payload = {\n  cachedAt:    now.toISOString(),\n  nextRefresh: nextRefresh.toISOString(),\n  data:        $input.first().json\n};\n\nfs.writeFileSync(cachePath, JSON.stringify(payload, null, 2), 'utf8');\n\nconsole.log('[Cache] Written to', cachePath, 'at', now.toISOString());\n\nreturn [{ json: {\n  success:     true,\n  cachedAt:    payload.cachedAt,\n  nextRefresh: payload.nextRefresh,\n  path:        cachePath\n}}];\n"
      }
    }
  ],

